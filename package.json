{
  "name": "@manyrows/manyrows-node",
  "version": "1.0.0",
  "description": "Official Node.js SDK for the ManyRows Server API",
  "license": "MIT",
  "homepage": "https://manyrows.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/manyrows/manyrows-node.git"
  },
  "bugs": {
    "url": "https://github.com/manyrows/manyrows-node/issues"
  },
  "keywords": [
    "manyrows",
    "auth",
    "rbac",
    "feature-flags",
    "user-management",
    "sdk"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
